# =============================================================================
# EditorConfig - omara-labs Workspace
# =============================================================================
# This file defines consistent coding styles across different editors and IDEs.
# It applies to the entire workspace. Individual repositories may override
# specific rules in their own .editorconfig if needed.
#
# https://editorconfig.org
# =============================================================================

root = true

# -----------------------------------------------------------------------------
# Default settings for all files
# -----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# -----------------------------------------------------------------------------
# Markdown files
# -----------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# -----------------------------------------------------------------------------
# Shell scripts
# -----------------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 2
shell_variant = bash

# -----------------------------------------------------------------------------
# Rust source files
# -----------------------------------------------------------------------------
[*.rs]
indent_style = space
indent_size = 4

# -----------------------------------------------------------------------------
# TOML / Configuration files
# -----------------------------------------------------------------------------
[*.toml]
indent_size = 2

# -----------------------------------------------------------------------------
# JSON files (usually 2 spaces is standard)
# -----------------------------------------------------------------------------
[*.json]
indent_size = 2

# -----------------------------------------------------------------------------
# YAML files
# -----------------------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# -----------------------------------------------------------------------------
# Makefiles (tabs are required)
# -----------------------------------------------------------------------------
[Makefile]
indent_style = tab

# -----------------------------------------------------------------------------
# Git-related files
# -----------------------------------------------------------------------------
[*.git{attributes,ignore}]
indent_style = tab
